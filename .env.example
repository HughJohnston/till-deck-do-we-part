# Supabase credentials for the global leaderboard.
# Copy this file to .env and fill in your project's values.
# Both are safe to ship in a browser bundle (the publishable key relies on
# Row Level Security policies on the `scores` table).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: hide leaderboard rows before this UTC instant (ISO-8601). Old rows
# remain in Supabase; only fetches are filtered. Default = 2026-06-25T23:00:00Z
# (26 Jun 2026 00:00 UK / BST).
# VITE_LEADERBOARD_RESET_AFTER=2026-06-25T23:00:00Z

# Player stats (time, games, bests, synergy, etc.) use the same Supabase project.
# Run supabase/player_stats.sql once in the Supabase SQL editor (idempotent v2).
